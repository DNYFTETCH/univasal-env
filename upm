#!/usr/bin/env bash
#
# UPM - Universal Package Manager
# Cross-platform package management wrapper
# Supports: Termux, macOS (Homebrew), Linux (apt/dnf/pacman), Windows (WSL)
#
# Usage: upm {install|remove|update|search|list} [package...]
#

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Logging functions
log_info() { echo -e "${GREEN}[INFO]${NC} $*"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $*"; }
log_error() { echo -e "${RED}[ERROR]${NC} $*" >&2; }

# Platform detection
detect_platform() {
  case "$OSTYPE" in
    linux-android*)
      echo "termux"
      ;;
    darwin*)
      echo "macos"
      ;;
    linux-gnu*)
      if [ -f /etc/os-release ]; then
        . /etc/os-release
        case "$ID" in
          ubuntu|debian) echo "debian" ;;
          fedora|rhel|centos|rocky|alma) echo "fedora" ;;
          arch|manjaro) echo "arch" ;;
          *) echo "linux" ;;
        esac
      else
        echo "linux"
      fi
      ;;
    msys*|cygwin*)
      echo "windows"
      ;;
    *)
      echo "unknown"
      ;;
  esac
}

# Package manager detection
detect_pkg_manager() {
  local platform="$1"
  
  case "$platform" in
    termux)
      echo "pkg"
      ;;
    macos)
      if command -v brew >/dev/null 2>&1; then
        echo "brew"
      else
        log_error "Homebrew not found. Install from https://brew.sh"
        exit 1
      fi
      ;;
    debian)
      echo "apt"
      ;;
    fedora)
      if command -v dnf >/dev/null 2>&1; then
        echo "dnf"
      else
        echo "yum"
      fi
      ;;
    arch)
      echo "pacman"
      ;;
    *)
      log_error "Unsupported platform: $platform"
      exit 1
      ;;
  esac
}

# Check for sudo requirement
needs_sudo() {
  local platform="$1"
  
  case "$platform" in
    termux|macos)
      echo "no"
      ;;
    *)
      if [ "$EUID" -eq 0 ]; then
        echo "no"
      else
        echo "yes"
      fi
      ;;
  esac
}

# Execute command with optional sudo
run_cmd() {
  local use_sudo="$1"
  shift
  
  if [ "$use_sudo" = "yes" ]; then
    sudo "$@"
  else
    "$@"
  fi
}

# Main package operations
upm_install() {
  local platform pkg_mgr use_sudo
  platform=$(detect_platform)
  pkg_mgr=$(detect_pkg_manager "$platform")
  use_sudo=$(needs_sudo "$platform")
  
  log_info "Installing packages on $platform using $pkg_mgr..."
  
  case "$pkg_mgr" in
    pkg)
      pkg install -y "$@"
      ;;
    brew)
      brew install "$@"
      ;;
    apt)
      run_cmd "$use_sudo" apt update
      run_cmd "$use_sudo" apt install -y "$@"
      ;;
    dnf|yum)
      run_cmd "$use_sudo" "$pkg_mgr" install -y "$@"
      ;;
    pacman)
      run_cmd "$use_sudo" pacman -S --needed --noconfirm "$@"
      ;;
  esac
}

upm_remove() {
  local platform pkg_mgr use_sudo
  platform=$(detect_platform)
  pkg_mgr=$(detect_pkg_manager "$platform")
  use_sudo=$(needs_sudo "$platform")
  
  log_info "Removing packages on $platform using $pkg_mgr..."
  
  case "$pkg_mgr" in
    pkg)
      pkg uninstall -y "$@"
      ;;
    brew)
      brew uninstall "$@"
      ;;
    apt)
      run_cmd "$use_sudo" apt remove -y "$@"
      ;;
    dnf|yum)
      run_cmd "$use_sudo" "$pkg_mgr" remove -y "$@"
      ;;
    pacman)
      run_cmd "$use_sudo" pacman -R --noconfirm "$@"
      ;;
  esac
}

upm_update() {
  local platform pkg_mgr use_sudo
  platform=$(detect_platform)
  pkg_mgr=$(detect_pkg_manager "$platform")
  use_sudo=$(needs_sudo "$platform")
  
  log_info "Updating packages on $platform using $pkg_mgr..."
  
  case "$pkg_mgr" in
    pkg)
      pkg update && pkg upgrade -y
      ;;
    brew)
      brew update && brew upgrade
      ;;
    apt)
      run_cmd "$use_sudo" apt update && run_cmd "$use_sudo" apt upgrade -y
      ;;
    dnf|yum)
      run_cmd "$use_sudo" "$pkg_mgr" update -y
      ;;
    pacman)
      run_cmd "$use_sudo" pacman -Syu --noconfirm
      ;;
  esac
}

upm_search() {
  local platform pkg_mgr
  platform=$(detect_platform)
  pkg_mgr=$(detect_pkg_manager "$platform")
  
  case "$pkg_mgr" in
    pkg)
      pkg search "$@"
      ;;
    brew)
      brew search "$@"
      ;;
    apt)
      apt search "$@"
      ;;
    dnf|yum)
      "$pkg_mgr" search "$@"
      ;;
    pacman)
      pacman -Ss "$@"
      ;;
  esac
}

upm_list() {
  local platform pkg_mgr
  platform=$(detect_platform)
  pkg_mgr=$(detect_pkg_manager "$platform")
  
  case "$pkg_mgr" in
    pkg)
      pkg list-installed
      ;;
    brew)
      brew list
      ;;
    apt)
      dpkg -l | grep '^ii'
      ;;
    dnf|yum)
      "$pkg_mgr" list installed
      ;;
    pacman)
      pacman -Q
      ;;
  esac
}

# Show help
show_help() {
  cat << EOF
UPM - Universal Package Manager v1.0

Usage: upm <command> [options] [packages...]

Commands:
  install, i    Install one or more packages
  remove, r     Remove one or more packages
  update, u     Update all packages
  search, s     Search for packages
  list, l       List installed packages
  help, h       Show this help message

Examples:
  upm install git vim tmux
  upm i python3 nodejs
  upm remove old-package
  upm update
  upm search docker
  upm list

Supported Platforms:
  - Termux (Android)       → pkg
  - macOS                  → Homebrew
  - Debian/Ubuntu          → apt
  - Fedora/RHEL/CentOS    → dnf/yum
  - Arch Linux             → pacman

Environment:
  Platform: $(detect_platform)
  Package Manager: $(detect_pkg_manager "$(detect_platform)" 2>/dev/null || echo "unknown")
  
Author: @dnyftetch
License: MIT
EOF
}

# Main command router
main() {
  if [ $# -eq 0 ]; then
    show_help
    exit 0
  fi
  
  local cmd="$1"
  shift
  
  case "$cmd" in
    install|i)
      if [ $# -eq 0 ]; then
        log_error "No packages specified"
        exit 1
      fi
      upm_install "$@"
      ;;
    remove|r|uninstall)
      if [ $# -eq 0 ]; then
        log_error "No packages specified"
        exit 1
      fi
      upm_remove "$@"
      ;;
    update|u|upgrade)
      upm_update
      ;;
    search|s)
      if [ $# -eq 0 ]; then
        log_error "No search term specified"
        exit 1
      fi
      upm_search "$@"
      ;;
    list|l|ls)
      upm_list
      ;;
    help|h|--help|-h)
      show_help
      ;;
    *)
      log_error "Unknown command: $cmd"
      echo ""
      show_help
      exit 1
      ;;
  esac
}

# Run main function
main "$@"
